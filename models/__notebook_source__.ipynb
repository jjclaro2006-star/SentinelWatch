import json
import numpy as np

# Cargar geojson
with open('/content/collected_locations2025-10-21T23_00.geojson') as f:
    gj = json.load(f)

feats = gj['features']

# Separar positivos y negativos en orden
pos_feats = [f for f in feats if f['properties']['label'] == 1]
neg_feats = [f for f in feats if f['properties']['label'] == 0]

print(f"Positivos en geojson: {len(pos_feats)}")
print(f"Negativos en geojson: {len(neg_feats)}")

# Reconstruir mapeo índice → coordenada
# El script de descarga usó i:04d como nombre de archivo
mapeo = {}
for i, feat in enumerate(pos_feats[:500]):  # muestra_pos tenía 500
    coord = feat['geometry']['coordinates']  # [lon, lat]
    mapeo[f"mineria/{i:04d}.npy"] = {
        'lon': coord[0], 'lat': coord[1],
        'start': feat['properties']['start_date'],
        'end': feat['properties']['end_date'],
        'label': 1
    }

for i, feat in enumerate(neg_feats[:5000]):  # muestra_neg tenía 5000
    coord = feat['geometry']['coordinates']
    mapeo[f"normal/{i:04d}.npy"] = {
        'lon': coord[0], 'lat': coord[1],
        'start': feat['properties']['start_date'],
        'end': feat['properties']['end_date'],
        'label': 0
    }

print(f"Mapeo creado: {len(mapeo)} entradas")
print(f"Ejemplo: {list(mapeo.items())[0]}")


# Conectar predicciones top 50 con coordenadas
coordenadas_validacion = []

for archivo, label_real, prob in predichos_mineria:
    # Extraer key relativa (mineria/0001.npy o normal/0001.npy)
    key = '/'.join(archivo.split('/')[-2:])

    if key in mapeo:
        info = mapeo[key]
        coordenadas_validacion.append({
            'lat': info['lat'],
            'lon': info['lon'],
            'prob': prob,
            'label_real': label_real
        })

print(f"Coordenadas encontradas: {len(coordenadas_validacion)}")

# Generar prompt para Codex
print("\n" + "="*60)
print("PROMPT PARA CODEX:")
print("="*60)

coords_texto = "\n".join([
    f"{i+1}. lat={r['lat']:.4f}, lon={r['lon']:.4f} (confianza: {r['prob']:.0%})"
    for i, r in enumerate(coordenadas_validacion[:50])
])

print(f"""Tengo un modelo de IA que detecta minería ilegal de oro (garimpo) en el Amazonas usando satélites. Necesito verificar {len(coordenadas_validacion[:50])} coordenadas para saber qué porcentaje realmente muestra garimpo.

Para cada coordenada abre Google Maps satelital: maps.google.com/?q=LAT,LON&t=k

Busca señales de garimpo:
- Pozas circulares de agua turbia (marrón, verde, turquesa)
