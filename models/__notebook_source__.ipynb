import torch
import numpy as np
import os
import sys
sys.path.append("/content/SSL4EO-S12/src/benchmark/transfer_classification")
from models.dino import vision_transformer as vits

# Cargar modelo guardado
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
backbone = vits.vit_small(patch_size=16, in_chans=12)
modelo_eval = GaiaMineria(backbone).to(device)
modelo_eval.load_state_dict(torch.load(
    "/content/drive/MyDrive/SentinelWatch/gaia_v05_amw_ssl4eo.pth",
    map_location=device
))
modelo_eval.eval()

# Evaluar sobre set de validación y sacar las 50 más confiadas como minería
resultados = []
with torch.no_grad():
    for i, (archivo, label) in enumerate(zip(X_val, y_val)):
        arr = np.load(archivo).astype(np.float32) / 10000.0
        tensor = torch.tensor(arr).permute(2, 0, 1).unsqueeze(0).to(device)
        prob = torch.sigmoid(modelo_eval(tensor)).item()
        resultados.append((archivo, label, prob))

# Top 50 predicciones de minería con mayor confianza
predichos_mineria = sorted(
    [r for r in resultados if r[2] > 0.5],
    key=lambda x: x[2], reverse=True
)[:50]

print(f"Total predichos como minería: {len([r for r in resultados if r[2] > 0.5])}")
print(f"Top 50 seleccionados para validación en campo")
print(f"\nNecesitamos las coordenadas originales de estos archivos para validar con Codex")



