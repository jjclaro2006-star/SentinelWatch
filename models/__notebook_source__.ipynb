plt.suptitle("Garimpo confirmado — 7 bandas", fontsize=14)
plt.tight_layout()
plt.show()


# Verificar cuántas imágenes muestran garimpo real
# usando BSI calculado sobre las imágenes descargadas

bsi_valores = []
for archivo in os.listdir(carpeta_test):
    if not archivo.endswith(".tif"):
        continue
    with rasterio.open(os.path.join(carpeta_test, archivo)) as src:
        img = src.read().astype(np.float32)
    # BSI con bandas: B4=0, B3=1, B2=2, B8=3, B11=4
    swir = img[4]
    red  = img[0]
    nir  = img[3]
    blue = img[2]
    bsi  = ((swir + red) - (nir + blue)) / ((swir + red) + (nir + blue) + 1e-8)
    bsi_valores.append((archivo, bsi.mean()))

# Filtrar solo las que tienen BSI alto = garimpo real
garimpo_real = [(f, v) for f, v in bsi_valores if v > 0.05]
bosque_falso  = [(f, v) for f, v in bsi_valores if v <= 0.05]

print(f"Con garimpo visible (BSI > 0.05): {len(garimpo_real)}")
print(f"Bosque/sin garimpo (BSI ≤ 0.05): {len(bosque_falso)}")
print(f"\nBSI promedio garimpo: {sum(v for _,v in garimpo_real)/len(garimpo_real):.3f}" if garimpo_real else "")


