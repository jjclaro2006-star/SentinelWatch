import os
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split
import sys
import importlib.util

# Cargar backbone SSL4EO
if not os.path.exists("/content/SSL4EO-S12"):
    import subprocess
    subprocess.run(["git", "clone", "https://github.com/zhu-xlab/SSL4EO-S12.git", "/content/SSL4EO-S12"], capture_output=True)

spec = importlib.util.spec_from_file_location(
    "vision_transformer",
    "/content/SSL4EO-S12/src/benchmark/transfer_classification/models/dino/vision_transformer.py"
)
vits = importlib.util.module_from_spec(spec)
spec_utils = importlib.util.spec_from_file_location(
    "utils",
    "/content/SSL4EO-S12/src/benchmark/transfer_classification/models/dino/utils.py"
)
utils_mod = importlib.util.module_from_spec(spec_utils)
sys.modules['utils'] = utils_mod
spec_utils.loader.exec_module(utils_mod)
sys.modules['models.dino.utils'] = utils_mod
spec.loader.exec_module(vits)

backbone = vits.vit_small(patch_size=16, in_chans=12)
checkpoint = torch.load("/content/drive/MyDrive/SentinelWatch/B13_vits16_moco_0099.pth", map_location="cpu")
state_dict = checkpoint['state_dict']
new_state_dict = {}
for k, v in state_dict.items():
    if k.startswith('module.base_encoder.'):
        new_state_dict[k.replace('module.base_encoder.', '')] = v
new_state_dict.pop('patch_embed.proj.weight', None)
new_state_dict.pop('patch_embed.proj.bias', None)
backbone.load_state_dict(new_state_dict, strict=False)

class GaiaAridos(nn.Module):
    def __init__(self, backbone):
        super().__init__()
        self.backbone = backbone
        self.classifier = nn.Sequential(
            nn.Linear(384, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, 1)
        )
    def forward(self, x):
        with torch.no_grad():
            features = self.backbone(x)
        return self.classifier(features)

# Dataset
class DatasetAridos(Dataset):
    def __init__(self, archivos, etiquetas):
        self.archivos = archivos
        self.etiquetas = etiquetas
    def __len__(self):
        return len(self.archivos)
    def __getitem__(self, idx):
        arr = np.load(self.archivos[idx]).astype(np.float32) / 10000.0
        tensor = torch.tensor(arr).permute(2, 0, 1)
        label = torch.tensor(self.etiquetas[idx], dtype=torch.float32)
        return tensor, label

base_aridos = "/content/drive/MyDrive/SentinelWatch/data_aridos"
archivos, etiquetas = [], []

for f in sorted(os.listdir(f"{base_aridos}/positivos")):
    archivos.append(f"{base_aridos}/positivos/{f}")
    etiquetas.append(1)

for f in sorted(os.listdir(f"{base_aridos}/negativos")):
    archivos.append(f"{base_aridos}/negativos/{f}")
    etiquetas.append(0)

print(f"Positivos: {etiquetas.count(1)}")
print(f"Negativos: {etiquetas.count(0)}")

X_train, X_val, y_train, y_val = train_test_split(
    archivos, etiquetas, test_size=0.2, random_state=42, stratify=etiquetas
)

train_ds = DatasetAridos(X_train, y_train)
val_ds = DatasetAridos(X_val, y_val)

train_loader = DataLoader(train_ds, batch_size=16, shuffle=True, num_workers=0)
val_loader = DataLoader(val_ds, batch_size=16, shuffle=False, num_workers=0)

device = torch.device("cpu")
print(f"Device: {device}")

# Congelar backbone
for param in backbone.parameters():
    param.requires_grad = False

modelo = GaiaAridos(backbone).to(device)

pos_weight = torch.tensor([5.0])
criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
optimizer = optim.Adam(modelo.classifier.parameters(), lr=1e-4)
scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=3, factor=0.5)

mejor_val_loss = float('inf')
paciencia = 0
MAX_PACIENCIA = 7

print("\nArrancando entrenamiento en CPU...")
import time

for epoca in range(30):
    t0 = time.time()
    modelo.train()
    train_loss = 0
    for imgs, labels in train_loader:
        optimizer.zero_grad()
        preds = modelo(imgs).squeeze()
        loss = criterion(preds, labels)
        loss.backward()
        optimizer.step()
        train_loss += loss.item()

    modelo.eval()
    val_loss = 0
    correctas = 0
    total = 0
    with torch.no_grad():
        for imgs, labels in val_loader:
            preds = modelo(imgs).squeeze()
            val_loss += criterion(preds, labels).item()
            predicted = (torch.sigmoid(preds) > 0.5).float()
            correctas += (predicted == labels).sum().item()
            total += labels.size(0)

    train_loss /= len(train_loader)
    val_loss /= len(val_loader)
    accuracy = correctas / total * 100
    t1 = time.time()

    print(f"Época {epoca+1:02d} | Train: {train_loss:.4f} | Val: {val_loss:.4f} | Acc: {accuracy:.1f}% | {t1-t0:.0f}s")

    scheduler.step(val_loss)

    if val_loss < mejor_val_loss:
        mejor_val_loss = val_loss
        paciencia = 0
        torch.save(modelo.state_dict(),
                   "/content/drive/MyDrive/SentinelWatch/gaia_aridos_v01.pth")
