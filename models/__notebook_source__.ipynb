import sys, importlib.util, random, glob, time
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split

# ── Backbone SSL4EO ──────────────────────────────────────────────────────────
if not os.path.exists("/kaggle/working/SSL4EO-S12"):
    import subprocess
    subprocess.run(["git", "clone", "https://github.com/zhu-xlab/SSL4EO-S12.git",
                   "/kaggle/working/SSL4EO-S12"], capture_output=True)

spec = importlib.util.spec_from_file_location(
    "vision_transformer",
    "/kaggle/working/SSL4EO-S12/src/benchmark/transfer_classification/models/dino/vision_transformer.py"
)
vits = importlib.util.module_from_spec(spec)
spec_utils = importlib.util.spec_from_file_location(
    "utils",
    "/kaggle/working/SSL4EO-S12/src/benchmark/transfer_classification/models/dino/utils.py"
)
utils_mod = importlib.util.module_from_spec(spec_utils)
sys.modules['utils'] = utils_mod
