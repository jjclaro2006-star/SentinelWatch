from sklearn.metrics import roc_curve
import numpy as np

# Recalcular predicciones
model.eval()
all_preds, all_labels = [], []
with torch.no_grad():
    for x, y in val_loader:
        probs = torch.sigmoid(model(x.to(DEVICE)).squeeze(1)).cpu().numpy()
        all_preds.extend(probs)
        all_labels.extend(y.numpy())

fpr, tpr, thresholds = roc_curve(all_labels, all_preds)

# Encontrar umbral óptimo — maximiza recall con precision > 0.4
print("=== Análisis de umbrales ===")
for threshold in [0.1, 0.15, 0.2, 0.25, 0.3, 0.35, 0.4, 0.5]:
    preds = [1 if p > threshold else 0 for p in all_preds]
    tp = sum(1 for p, l in zip(preds, all_labels) if p == 1 and l == 1)
    fp = sum(1 for p, l in zip(preds, all_labels) if p == 1 and l == 0)
    fn = sum(1 for p, l in zip(preds, all_labels) if p == 0 and l == 1)
    recall    = tp / (tp + fn) if (tp + fn) > 0 else 0
    precision = tp / (tp + fp) if (tp + fp) > 0 else 0
    f1        = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0
    print(f"  Umbral {threshold:.2f} | Recall {recall:.3f} | Precision {precision:.3f} | F1 {f1:.3f} | TP {tp} | FP {fp} | FN {fn}")


torch.save({
    'epoch': 30,
    'model_state_dict': model.state_dict(),
    'auc': 0.748,
    'recall': 0.796,
    'precision': 0.206,
    'threshold': 0.15,
    'version': 'v0.2',
    'notas': 'Umbral 0.15 — recall 0.796. 4,209 parches. Mejora con más datos CONAF.'
}, os.path.join(WORK_DIR, "gaia_incendios_v02_final.pth"))
print("✅ Modelo v0.2 guardado con umbral 0.15")


# Opción B — descongelar últimas 3 capas del backbone + umbral optimizado

# Descongelar últimos 3 bloques del transformer
for name, param in model.backbone.named_parameters():
    if any(f'blocks.{i}' in name for i in [9, 10, 11]):
        param.requires_grad = True
        
# Contar parámetros entrenables
trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
total     = sum(p.numel() for p in model.parameters())
print(f"Parámetros entrenables: {trainable:,} de {total:,} ({100*trainable/total:.1f}%)")

# Optimizer con lr diferenciado
# Backbone descongelado: lr muy bajo para no destruir preentrenamiento
# Clasificador: lr normal
optimizer = torch.optim.AdamW([
    {'params': [p for n, p in model.backbone.named_parameters() 
                if p.requires_grad], 'lr': 1e-5},
    {'params': model.classifier.parameters(), 'lr': 1e-4}
], weight_decay=1e-4)

scheduler  = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=30)
pos_weight = torch.tensor([2.0]).to(DEVICE)  # subido para mejorar recall
criterion  = nn.BCEWithLogitsLoss(pos_weight=pos_weight)

best_auc = 0.748  # partir desde el mejor anterior
history  = []

print("\n🚀 Fine-tuning — 30 épocas con backbone parcialmente descongelado...")
for epoch in range(1, 31):
