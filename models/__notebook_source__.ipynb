import random
import math

def generar_negativos(lat, lon, n=5, min_km=2, max_km=10):
    negativos = []
    for _ in range(n):
        distancia_km = random.uniform(min_km, max_km)
        angulo = random.uniform(0, 2 * math.pi)
        delta_lat = (distancia_km / 111) * math.cos(angulo)
        delta_lon = (distancia_km / (111 * math.cos(math.radians(lat)))) * math.sin(angulo)
        negativos.append({'lat': lat + delta_lat, 'lon': lon + delta_lon})
    return negativos

# Generar negativos para todos los positivos
todos_positivos = []

# Shi-ting
