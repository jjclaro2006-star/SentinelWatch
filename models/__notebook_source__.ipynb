# NBR para detectar cicatrices de incendio
# NBR = (B8 - B12) / (B8 + B12)
# NBR bajo = área quemada reciente

# Zonas conocidas de incendios en LATAM 2023
# Cerrado brasileño tiene incendios masivos cada año en época seca (julio-octubre)

zonas_incendio_2023 = ee.Geometry.BBox(-55, -18, -44, -8)  # Cerrado

# Colección época seca 2023
col_pre  = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterBounds(zonas_incendio_2023)
    .filterDate("2023-04-01", "2023-06-30")  # antes del incendio
    .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
    .median()
)

col_post = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterBounds(zonas_incendio_2023)
    .filterDate("2023-08-01", "2023-10-31")  # después del incendio
    .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
    .median()
)

# dNBR = NBR_pre - NBR_post
# dNBR alto = área quemada
def calcular_nbr(img):
    return img.normalizedDifference(["B8", "B12"]).rename("NBR")

nbr_pre  = calcular_nbr(col_pre)
nbr_post = calcular_nbr(col_post)
dnbr = nbr_pre.subtract(nbr_post).rename("dNBR")

# Cicatrices de quema moderada-alta
cicatrices = dnbr.gt(0.27)

puntos_incendio_real = cicatrices.selfMask().sample(
    region=zonas_incendio_2023,
    scale=100,
    numPixels=2000,
    seed=42,
    geometries=True,
    tileScale=4
)

cantidad = puntos_incendio_real.size().getInfo()
