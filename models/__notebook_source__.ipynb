import numpy as np
import rasterio
import os

def calcular_ndwi(archivo):
    """NDWI = (B3 - B8) / (B3 + B8) — valores altos = agua"""
    with rasterio.open(archivo) as src:
        img = src.read().astype(np.float32)
    b3 = img[1]  # Verde
    b8 = img[3]  # NIR
    ndwi = (b3 - b8) / (b3 + b8 + 1e-8)
    return ndwi.mean()

