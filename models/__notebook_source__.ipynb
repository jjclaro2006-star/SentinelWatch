for coord in ciudades_brasil:
    puntos_asentamiento.extend(generar_puntos_alrededor(coord, n=55))

puntos_incendio = []
for coord in zonas_incendio:
    puntos_incendio.extend(generar_puntos_alrededor(coord, n=55))

