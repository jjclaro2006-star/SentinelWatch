import torch.nn as nn

class GaiaMineria(nn.Module):
    def __init__(self, backbone):
        super().__init__()
        self.backbone = backbone
        self.classifier = nn.Sequential(
            nn.Linear(384, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, 1)
        )

    def forward(self, x):
        with torch.no_grad():  # Backbone congelado
            features = self.backbone(x)
        return self.classifier(features)

# Instanciar modelo
modelo = GaiaMineria(backbone)
print("✓ Modelo Gaia completo")
print(f"Parámetros entrenables: {sum(p.numel() for p in modelo.classifier.parameters()):,}")
print(f"Parámetros congelados: {sum(p.numel() for p in modelo.backbone.parameters()):,}")


import os
import numpy as np
import torch
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split

class DatasetMineria(Dataset):
    def __init__(self, archivos, etiquetas):
        self.archivos = archivos
        self.etiquetas = etiquetas

    def __len__(self):
        return len(self.archivos)

    def __getitem__(self, idx):
        arr = np.load(self.archivos[idx]).astype(np.float32)
        # Normalizar a [0, 1]
        arr = arr / 10000.0
        # (224, 224, 12) → (12, 224, 224)
        arr = torch.tensor(arr).permute(2, 0, 1)
        label = torch.tensor(self.etiquetas[idx], dtype=torch.float32)
        return arr, label

# Cargar paths y etiquetas
base_amw = "/content/drive/MyDrive/SentinelWatch/data_amw_oficial"

archivos, etiquetas = [], []
for f in sorted(os.listdir(f"{base_amw}/mineria")):
    archivos.append(f"{base_amw}/mineria/{f}")
    etiquetas.append(1)
for f in sorted(os.listdir(f"{base_amw}/normal")):
    archivos.append(f"{base_amw}/normal/{f}")
    etiquetas.append(0)

# Split train/val 80/20
X_train, X_val, y_train, y_val = train_test_split(
    archivos, etiquetas, test_size=0.2, random_state=42, stratify=etiquetas
)

train_ds = DatasetMineria(X_train, y_train)
val_ds = DatasetMineria(X_val, y_val)

train_loader = DataLoader(train_ds, batch_size=32, shuffle=True, num_workers=2)
val_loader = DataLoader(val_ds, batch_size=32, shuffle=False, num_workers=2)

print(f"✓ Train: {len(train_ds)} imágenes")
print(f"✓ Val:   {len(val_ds)} imágenes")


import torch.optim as optim
from torch.optim.lr_scheduler import ReduceLROnPlateau

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Device: {device}")

modelo = modelo.to(device)

# Loss con peso para clase positiva (desbalance 10:1)
pos_weight = torch.tensor([10.0]).to(device)
criterion = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
optimizer = optim.Adam(modelo.classifier.parameters(), lr=1e-4)
scheduler = ReduceLROnPlateau(optimizer, patience=3, factor=0.5, verbose=True)

mejor_val_loss = float('inf')
paciencia = 0
MAX_PACIENCIA = 7

for epoca in range(30):
    # Training
    modelo.train()
    train_loss = 0
    for imgs, labels in train_loader:
        imgs, labels = imgs.to(device), labels.to(device)
        optimizer.zero_grad()
        preds = modelo(imgs).squeeze()
        loss = criterion(preds, labels)
        loss.backward()
        optimizer.step()
        train_loss += loss.item()

    # Validación
    modelo.eval()
    val_loss = 0
    correctas = 0
    total = 0
    with torch.no_grad():
        for imgs, labels in val_loader:
            imgs, labels = imgs.to(device), labels.to(device)
            preds = modelo(imgs).squeeze()
            val_loss += criterion(preds, labels).item()
            predicted = (torch.sigmoid(preds) > 0.5).float()
            correctas += (predicted == labels).sum().item()
            total += labels.size(0)

    train_loss /= len(train_loader)
    val_loss /= len(val_loader)
    accuracy = correctas / total * 100

    print(f"Época {epoca+1:02d} | Train Loss: {train_loss:.4f} | Val Loss: {val_loss:.4f} | Val Acc: {accuracy:.1f}%")

    scheduler.step(val_loss)

    # Guardar mejor modelo
    if val_loss < mejor_val_loss:
        mejor_val_loss = val_loss
        paciencia = 0
        torch.save(modelo.state_dict(),
                   "/content/drive/MyDrive/SentinelWatch/gaia_v05_amw_ssl4eo.pth")
        print(f"  ✓ Mejor modelo guardado")
    else:
        paciencia += 1
        if paciencia >= MAX_PACIENCIA:
            print(f"\nEarly stopping en época {epoca+1}")
            break

print("\n✓ Entrenamiento completo")


