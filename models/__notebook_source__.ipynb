class SSL4EODataset(Dataset):
    def __init__(self, archivos, etiquetas, augment=False):
        self.archivos = archivos
        self.etiquetas = etiquetas
        self.augment = augment
    def __len__(self):
        return len(self.archivos)
    def __getitem__(self, idx):
        arr = np.load(self.archivos[idx])
        arr = arr / 10000.0
        arr = np.clip(arr, 0, 1)
        tensor = torch.tensor(arr.transpose(2, 0, 1), dtype=torch.float32)
        b10 = torch.zeros(1, 224, 224)
        tensor = torch.cat([tensor[:9], b10, tensor[9:]], dim=0)
        if self.augment:
            if random.random() > 0.5:
                tensor = torch.flip(tensor, dims=[2])
            if random.random() > 0.5:
                tensor = torch.flip(tensor, dims=[1])
            if random.random() > 0.5:
                tensor = torch.rot90(tensor, k=random.randint(1,3), dims=[1,2])
        return tensor, self.etiquetas[idx]

