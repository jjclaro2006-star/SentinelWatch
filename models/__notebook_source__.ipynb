        "fecha_fin": "2023-10-31"
    },
    {
        "nombre": "agricultura",
        "puntos": puntos_agri_lista,
        "carpeta": "/content/drive/MyDrive/SentinelWatch/data_v04_fixed/agricultura",
        "fecha_inicio": "2023-01-01",
        "fecha_fin": "2024-01-01"
    }
]

for descarga in descargas:
    os.makedirs(descarga["carpeta"], exist_ok=True)
    print(f"\nDescargando {descarga['nombre']}...\n")
    errores = 0
    descargadas = 0

    for i in range(800):
        archivo = f"{descarga['carpeta']}/img_{i:04d}.tif"
        if os.path.exists(archivo):
            descargadas += 1
            continue
        try:
            punto = ee.Feature(descarga["puntos"].get(i))
            geom = punto.geometry().buffer(320)
            imagen = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
                .filterBounds(geom)
                .filterDate(descarga["fecha_inicio"], descarga["fecha_fin"])
                .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
                .median()
                .select(["B4", "B3", "B2", "B8"])
            )
            url = imagen.getDownloadURL({"region": geom, "scale": 10, "format": "NPY"})
            response = requests.get(url)
            data = np.load(io.BytesIO(response.content))
            data = np.stack([data["B4"], data["B3"], data["B2"], data["B8"]], axis=-1)
            data = resize(data.astype(np.float32), (64, 64, 4), anti_aliasing=True).astype(np.float32)
            with rasterio.open(archivo, "w", driver="GTiff",
                             height=64, width=64, count=4, dtype=np.float32) as dst:
                for b in range(4):
                    dst.write(data[:,:,b], b+1)
            descargadas += 1
            if descargadas % 100 == 0:
                print(f"  {descargadas}/800")
        except:
            errores += 1
        time.sleep(0.3)

    print(f"✓ {descarga['nombre']}: {descargadas} descargadas, {errores} errores")

