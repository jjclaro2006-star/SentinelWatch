            'vit_small_patch16_224', pretrained=False, in_chans=13)

        state      = torch.load(backbone_path, map_location='cpu')
        state_dict = state.get('state_dict', state)

        # FIX — remapear prefijo base_ al formato timm
        remapped = {}
        for k, v in state_dict.items():
            if k.startswith('base_'):
                new_k = k.replace('base_', '')          # base_blocks → blocks
                new_k = new_k.replace('cls_token', 'cls_token')
                new_k = new_k.replace('pos_embed', 'pos_embed')
                new_k = new_k.replace('patch_embed', 'patch_embed')
                remapped[new_k] = v

        missing, unexpected = self.backbone.load_state_dict(remapped, strict=False)
        print(f"Backbone — missing: {len(missing)} | unexpected: {len(unexpected)}")
        print(f"Keys cargadas correctamente: {len(remapped) - len(unexpected)}")

        # Congelar todo el backbone
        for param in self.backbone.parameters():
            param.requires_grad = False

        self.classifier = nn.Sequential(
            nn.Linear(self.backbone.embed_dim, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, 1)
        )

    def forward(self, x):
        with torch.no_grad():
            features = self.backbone.forward_features(x)
            if features.ndim == 3:
                features = features[:, 0, :]
        return self.classifier(features)

