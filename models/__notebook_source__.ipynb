import os, random
import numpy as np, pandas as pd
import torch, torch.nn as nn
import matplotlib.pyplot as plt
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split
from sklearn.metrics import (classification_report, roc_auc_score,
                             confusion_matrix, roc_curve)

SEED          = 42
WORK_DIR      = "/kaggle/working/"
INPUT_PATCHES = "/kaggle/input/datasets/juanclaro/sentinelwatch-patches-biobio/patches-20260625T180312Z-3-001/patches/"
BACKBONE_PATH = "/kaggle/input/datasets/juanclaro/ssl4eo/B13_vits16_moco_0099.pth"

random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"✅ Device: {DEVICE}")

# ─────────────────────────────────────────────────────────────
# RECONSTRUIR MANIFEST COMPLETO
# ─────────────────────────────────────────────────────────────
TRAIN_SPLIT = "/kaggle/input/datasets/juanclaro/sentinelwatch-patches-biobio/train_split.csv"
train_df    = pd.read_csv(TRAIN_SPLIT)

# Parches del dataset original
npy_input = set(os.listdir(INPUT_PATCHES))
existing  = {int(f.replace('train_','').replace('.npy',''))
             for f in npy_input if f.endswith('.npy') and f.startswith('train_')}

# Parches nuevos descargados esta sesión
NEW_PATCHES = os.path.join(WORK_DIR, "patches/")
npy_new     = set(os.listdir(NEW_PATCHES)) if os.path.exists(NEW_PATCHES) else set()
new_idx     = {int(f.replace('train_','').replace('.npy',''))
               for f in npy_new if f.endswith('.npy') and f.startswith('train_')}

# Manifest completo
results = []
for idx, row in train_df.iterrows():
    if idx in existing:
        results.append({'idx': idx, 'label': row['label'],
                        'path': os.path.join(INPUT_PATCHES, f"train_{idx}.npy"),
                        'ok': True})
    elif idx in new_idx:
        results.append({'idx': idx, 'label': row['label'],
                        'path': os.path.join(NEW_PATCHES, f"train_{idx}.npy"),
                        'ok': True})
    else:
        results.append({'idx': idx, 'label': row['label'],
                        'path': None, 'ok': False})

manifest = pd.DataFrame(results)
manifest_ok = manifest[manifest['ok'] == True].reset_index(drop=True)
print(f"✅ Total parches válidos: {len(manifest_ok)}")
print(f"   Positivos: {manifest_ok['label'].sum()}")
print(f"   Negativos: {(manifest_ok['label']==0).sum()}")

# ─────────────────────────────────────────────────────────────
# SPLIT TRAIN/VAL
# ─────────────────────────────────────────────────────────────
train_manifest, val_manifest = train_test_split(
    manifest_ok, test_size=0.2,
    stratify=manifest_ok['label'],
    random_state=SEED)
print(f"Train: {len(train_manifest)} | Val: {len(val_manifest)}")

# ─────────────────────────────────────────────────────────────
# DATASET
# ─────────────────────────────────────────────────────────────
class IncendiosDataset(Dataset):
    def __init__(self, df, augment=False):
        self.data    = df.reset_index(drop=True)
        self.augment = augment

    def __len__(self): return len(self.data)

    def __getitem__(self, idx):
        row   = self.data.iloc[idx]
        patch = np.load(row['path'])
        if self.augment:
            if random.random() > 0.5: patch = np.fliplr(patch)
            if random.random() > 0.5: patch = np.flipud(patch)
            patch = np.rot90(patch, random.randint(0, 3))
        patch = np.ascontiguousarray(patch).transpose(2, 0, 1)
        return (torch.tensor(patch, dtype=torch.float32),
                torch.tensor(row['label'], dtype=torch.float32))

train_dataset = IncendiosDataset(train_manifest, augment=True)
val_dataset   = IncendiosDataset(val_manifest,   augment=False)
train_loader  = DataLoader(train_dataset, batch_size=16, shuffle=True,  num_workers=2, pin_memory=True)
val_loader    = DataLoader(val_dataset,   batch_size=16, shuffle=False, num_workers=2, pin_memory=True)
print(f"Train batches: {len(train_loader)} | Val batches: {len(val_loader)}")

# ─────────────────────────────────────────────────────────────
# MODELO
# ─────────────────────────────────────────────────────────────
class GaiaIncendios(nn.Module):
    def __init__(self, backbone_path):
        super().__init__()
        import timm
        self.backbone = timm.create_model(
            'vit_small_patch16_224', pretrained=False, in_chans=13)
        state      = torch.load(backbone_path, map_location='cpu')
        state_dict = state.get('state_dict', state)
        state_dict = {k.replace('module.','').replace('encoder.',''): v
                      for k, v in state_dict.items()}
        missing, unexpected = self.backbone.load_state_dict(state_dict, strict=False)
        print(f"Backbone — missing: {len(missing)} | unexpected: {len(unexpected)}")
        for param in self.backbone.parameters():
            param.requires_grad = False
        self.classifier = nn.Sequential(
            nn.Linear(self.backbone.embed_dim, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, 1)
        )

    def forward(self, x):
        with torch.no_grad():
            features = self.backbone.forward_features(x)
            if features.ndim == 3:
                features = features[:, 0, :]
        return self.classifier(features)

model = GaiaIncendios(BACKBONE_PATH).to(DEVICE)

# ─────────────────────────────────────────────────────────────
# ENTRENAMIENTO
# ─────────────────────────────────────────────────────────────
pos_weight = torch.tensor([2.6]).to(DEVICE)
criterion  = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
optimizer  = torch.optim.AdamW(model.classifier.parameters(), lr=1e-3, weight_decay=1e-4)
scheduler  = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=20)

best_auc = 0.0
history  = []

print("\n🚀 Entrenando 30 épocas...")
for epoch in range(1, 31):
    model.train()
    train_loss = 0.0
    for x, y in train_loader:
        x, y = x.to(DEVICE), y.to(DEVICE)
        optimizer.zero_grad()
        loss = criterion(model(x).squeeze(1), y)
        loss.backward()
        optimizer.step()
        train_loss += loss.item()
    scheduler.step()

    model.eval()
    all_preds, all_labels = [], []
    with torch.no_grad():
        for x, y in val_loader:
            x, y = x.to(DEVICE), y.to(DEVICE)
            probs = torch.sigmoid(model(x).squeeze(1)).cpu().numpy()
            all_preds.extend(probs)
            all_labels.extend(y.cpu().numpy())

    auc          = roc_auc_score(all_labels, all_preds)
    preds_binary = [1 if p > 0.35 else 0 for p in all_preds]
    report       = classification_report(all_labels, preds_binary,
                       target_names=['no_intencional','intencional'],
                       output_dict=True)

    recall    = report['intencional']['recall']
    precision = report['intencional']['precision']
    f1        = report['intencional']['f1-score']

    print(f"Epoch {epoch:02d} | Loss {train_loss/len(train_loader):.3f} | "
          f"AUC {auc:.3f} | Recall {recall:.3f} | "
          f"Precision {precision:.3f} | F1 {f1:.3f}")

    history.append({'epoch': epoch, 'auc': auc,
                    'recall': recall, 'precision': precision})

    if auc > best_auc and auc > 0.75:
        best_auc = auc
        torch.save({
            'epoch': epoch,
            'model_state_dict': model.state_dict(),
            'auc': auc, 'recall': recall, 'threshold': 0.35
        }, os.path.join(WORK_DIR, "gaia_incendios_v01_best.pth"))
        print(f"  💾 Modelo guardado — AUC {auc:.3f}")

pd.DataFrame(history).to_csv(os.path.join(WORK_DIR, "training_history.csv"), index=False)
print(f"\n✅ Entrenamiento completo — mejor AUC: {best_auc:.3f}")

# ─────────────────────────────────────────────────────────────
# EVALUACIÓN FINAL
# ─────────────────────────────────────────────────────────────
model.eval()
all_preds, all_labels = [], []
with torch.no_grad():
    for x, y in val_loader:
        probs = torch.sigmoid(model(x.to(DEVICE)).squeeze(1)).cpu().numpy()
        all_preds.extend(probs)
        all_labels.extend(y.numpy())

fpr, tpr, _ = roc_curve(all_labels, all_preds)
auc         = roc_auc_score(all_labels, all_preds)

plt.figure(figsize=(8,6))
plt.plot(fpr, tpr, label=f'AUC = {auc:.3f}')
plt.plot([0,1],[0,1],'--', color='gray')
plt.xlabel('False Positive Rate')
plt.ylabel('Recall')
plt.title('Gaia Incendios v0.1 — ROC Curve')
plt.legend()
plt.savefig(os.path.join(WORK_DIR, "roc_curve.png"))
plt.show()

preds_binary = [1 if p > 0.35 else 0 for p in all_preds]
print("\n=== Reporte Final — umbral 0.35 ===")
print(classification_report(all_labels, preds_binary,
                            target_names=['no_intencional','intencional']))

cm = confusion_matrix(all_labels, preds_binary)
print(f"\nMatriz de confusión:")
print(f"  TN: {cm[0,0]} | FP: {cm[0,1]}")
print(f"  FN: {cm[1,0]} | TP: {cm[1,1]}")
print(f"\nFalsos negativos: {cm[1,0]}")
print(f"Falsos positivos: {cm[0,1]}")


