# Filtrar imágenes mal etiquetadas usando NDVI
# NDVI alto = bosque verde = no debería estar en deforestación/incendio
# NDVI bajo = tierra/quemado = no debería estar en normal/agricultura densa

def calcular_ndvi_imagen(archivo):
    with rasterio.open(archivo) as src:
        img = src.read().astype(np.float32)
    # B8 (NIR) = banda 3, B4 (Red) = banda 0
    nir = img[3]
    red = img[0]
    ndvi = (nir - red) / (nir + red + 1e-8)
    return ndvi.mean()

print("Analizando calidad de imágenes por clase...\n")

resultados = {}

for clase in ["deforestacion", "agricultura", "incendio"]:
    archivos_clase = []
    for carpeta in [
        f"/content/drive/MyDrive/SentinelWatch/data_v02/{clase}",
        f"/content/drive/MyDrive/SentinelWatch/data_v04/{clase}"
    ]:
        if os.path.exists(carpeta):
            for f in os.listdir(carpeta):
                if f.endswith(".tif"):
                    archivos_clase.append(os.path.join(carpeta, f))

    ndvis = []
    for archivo in archivos_clase[:100]:  # muestra de 100
        ndvi = calcular_ndvi_imagen(archivo)
        ndvis.append(ndvi)

    ndvi_promedio = np.mean(ndvis)
    ndvi_alto = sum(1 for n in ndvis if n > 0.4)  # bosque sano
    ndvi_bajo = sum(1 for n in ndvis if n < 0.2)  # tierra/quemado

    resultados[clase] = ndvis
    print(f"{clase}:")
    print(f"  NDVI promedio: {ndvi_promedio:.3f}")
    print(f"  Imágenes con NDVI alto >0.4 (bosque): {ndvi_alto}/100")
    print(f"  Imágenes con NDVI bajo <0.2 (tierra):  {ndvi_bajo}/100")
    print()


