import random

def generar_puntos_alrededor(coord, n=55, radio=0.5):
    """Genera n puntos aleatorios dentro de un radio en grados"""
    puntos = []
    for _ in range(n):
        lat = coord[1] + random.uniform(-radio, radio)
        lon = coord[0] + random.uniform(-radio, radio)
        puntos.append([lon, lat])
    return puntos

# Generar 800+ puntos para cada clase
