        response = requests.get(url)
        data = np.load(io.BytesIO(response.content))

        # 7 bandas: B4,B3,B2,B8,B11,VV,VH
        arr = np.stack([data["B4"],data["B3"],data["B2"],data["B8"],
                       data["B11"],data["VV"],data["VH"]], axis=-1)
        arr = resize(arr.astype(np.float32),(64,64,7),anti_aliasing=True).astype(np.float32)

        with rasterio.open(archivo,"w",driver="GTiff",
                          height=64,width=64,count=7,dtype=np.float32) as dst:
            for b in range(7):
                dst.write(arr[:,:,b],b+1)
        descargadas += 1
        if descargadas % 20 == 0:
            print(f"  {descargadas}/100")
