    ee.Geometry.BBox(-55, -10, -51, -6),   # Pará centro
]

puntos_deforestacion_real = []

for i, region in enumerate(subregiones_deforestacion):
    try:
        # Antes: bosque sano
        col_antes = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
            .filterBounds(region)
            .filterDate("2022-06-01", "2022-08-31")
            .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
            .median()
        )
        # Después: sin vegetación
        col_despues = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
            .filterBounds(region)
            .filterDate("2023-06-01", "2023-08-31")
            .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
            .median()
        )

        ndvi_antes   = col_antes.normalizedDifference(["B8", "B4"])
        ndvi_despues = col_despues.normalizedDifference(["B8", "B4"])
        cambio = ndvi_antes.subtract(ndvi_despues)

        # Cambio fuerte = deforestación real
        deforestado = cambio.gt(0.3).And(ndvi_antes.gt(0.4))

        puntos = deforestado.selfMask().sample(
            region=region,
            scale=200,
            numPixels=200,
            seed=42,
            geometries=True,
            tileScale=4
        )

        cantidad = puntos.size().getInfo()
        print(f"Subregión {i+1}: {cantidad} puntos deforestación")
        if cantidad > 0:
            puntos_deforestacion_real.append(puntos)

    except Exception as e:
        print(f"Subregión {i+1}: error")

total_def = sum(p.size().getInfo() for p in puntos_deforestacion_real)
print(f"\nTotal puntos deforestación real: {total_def}")


