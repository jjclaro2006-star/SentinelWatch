print(f"  0.2-0.4 (agua/costa): {sum(1 for n in ndwis_values if 0.2 < n <= 0.4)}")
print(f"  0.0-0.2 (mixto):      {sum(1 for n in ndwis_values if 0.0 < n <= 0.2)}")
print(f"  < 0.0 (tierra):       {sum(1 for n in ndwis_values if n <= 0.0)}")


