base_amw = "/content/drive/MyDrive/SentinelWatch/data_amw_oficial"
os.makedirs(f"{base_amw}/normal_v2", exist_ok=True)

def descargar_amw(coord, fecha_inicio, fecha_fin, archivo):
    geom = ee.Geometry.Point(coord).buffer(1120)
    s2 = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
        .filterBounds(geom)
        .filterDate(fecha_inicio, fecha_fin)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
        .median()
        .select(["B1","B2","B3","B4","B5","B6","B7","B8","B8A","B9","B11","B12"])
    )
    url = s2.getDownloadURL({"region": geom, "scale": 10, "format": "NPY"})
    response = requests.get(url)
    data = np.load(io.BytesIO(response.content))
    arr = np.stack([data[b] for b in ["B1","B2","B3","B4","B5","B6","B7","B8","B8A","B9","B11","B12"]], axis=-1)
    arr = resize(arr.astype(np.float32), (224, 224, 12), anti_aliasing=True)
    np.save(archivo, arr)

