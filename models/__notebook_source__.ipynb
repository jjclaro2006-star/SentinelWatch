optimizador = optim.Adam(modelo.parameters(), lr=0.0005)
scheduler   = optim.lr_scheduler.CosineAnnealingLR(optimizador, T_max=30)

EPOCAS = 30
mejor_precision = 0

print(f"\nEntrenando Gaia v0.5 en {device}...\n")

for epoca in range(EPOCAS):
