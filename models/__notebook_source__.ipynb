def calcular_ndvi(archivo):
    with rasterio.open(archivo) as src:
        img = src.read().astype(np.float32)
    nir = img[3]  # B8
    red = img[0]  # B4
    ndvi = (nir - red) / (nir + red + 1e-8)
    return ndvi.mean()

