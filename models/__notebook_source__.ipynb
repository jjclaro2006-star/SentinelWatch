LIMITE = 800

print("Balanceando dataset a 800 imágenes por clase...\n")

for clase in clases:
    carpeta = f"{base}/{clase}"
    archivos = [f for f in os.listdir(carpeta) if f.endswith(".tif")]

    if len(archivos) > LIMITE:
        # Priorizar los nuevos archivos (garimpo, bosque_fp)
        nuevos = [f for f in archivos if f.startswith("garimpo_") or f.startswith("bosque_fp_")]
        viejos = [f for f in archivos if f not in nuevos]

        # Mantener todos los nuevos y completar con viejos hasta 800
        if len(nuevos) >= LIMITE:
            mantener = random.sample(nuevos, LIMITE)
        else:
            mantener = nuevos + random.sample(viejos, LIMITE - len(nuevos))

        eliminar = [f for f in archivos if f not in mantener]
        for f in eliminar:
            os.remove(os.path.join(carpeta, f))

        print(f"  {clase}: {len(archivos)} → 800 ({len(eliminar)} eliminadas)")
    else:
        print(f"  {clase}: {len(archivos)} ✓")

print("\n✓ Dataset balanceado")


