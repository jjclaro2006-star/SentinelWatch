import os, time, ee
import numpy as np, pandas as pd
from tqdm import tqdm

BASE          = "/kaggle/input/datasets/juanclaro/sentinelwatch-patches-biobio/"
INPUT_PATCHES = BASE + "patches-20260625T180312Z-3-001/patches/"
TRAIN_SPLIT   = BASE + "train_split.csv"
WORK_DIR      = "/kaggle/working/"
NEW_PATCHES   = os.path.join(WORK_DIR, "patches/")
os.makedirs(NEW_PATCHES, exist_ok=True)

train_df  = pd.read_csv(TRAIN_SPLIT)
npy_files = set(os.listdir(INPUT_PATCHES))

# Índices ya en disco
existing_idx = {int(f.replace('train_','').replace('.npy',''))
                for f in npy_files if f.endswith('.npy')}
missing_idx  = set(train_df.index.tolist()) - existing_idx
print(f"Ya en disco: {len(existing_idx)}")
print(f"A descargar: {len(missing_idx)}")

BANDS = ['B1','B2','B3','B4','B5','B6','B7','B8','B8A','B9','B11','B12']

def get_sentinel2_patch(lat, lon, date_str, patch_size=224, cloud_pct=20):
    point  = ee.Geometry.Point([lon, lat])
    region = point.buffer(1500).bounds()
    date   = pd.to_datetime(date_str)
    pre_start  = (date - pd.Timedelta(days=60)).strftime('%Y-%m-%d')
    pre_end    = (date - pd.Timedelta(days=5)).strftime('%Y-%m-%d')
    post_start = (date + pd.Timedelta(days=5)).strftime('%Y-%m-%d')
    post_end   = (date + pd.Timedelta(days=60)).strftime('%Y-%m-%d')

    def get_composite(start, end):
        return (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
                .filterBounds(point)
                .filterDate(start, end)
                .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', cloud_pct))
                .select(BANDS)
                .median())
    try:
        pre_img  = get_composite(pre_start, pre_end)
