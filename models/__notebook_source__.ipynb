import random
import numpy as np

# Filtrar solo tierras en el Amazonas (estados AM, PA, RO, AC, AP, RR, MT)
estados_amazonia = ['AM', 'PA', 'RO', 'AC', 'AP', 'RR', 'MT']
ti_amazonia = ti[ti['uf_sigla'].isin(estados_amazonia)]
print(f"Tierras indígenas en Amazonía: {len(ti_amazonia)}")

# Extraer centroides
ti_amazonia = ti_amazonia.to_crs('EPSG:4326')
centroides = ti_amazonia.geometry.centroid

# Generar puntos en los BORDES de las tierras indígenas
# Los asentamientos ilegales ocurren en los límites, no adentro
puntos_asentamiento_funai = []

for idx, geom in enumerate(ti_amazonia.geometry):
    try:
        # Centroide del borde (zona de presión)
        bounds = geom.bounds  # minx, miny, maxx, maxy
        lon_centro = (bounds[0] + bounds[2]) / 2
        lat_centro = (bounds[1] + bounds[3]) / 2

        # Generar puntos cerca del borde exterior
        radio = 0.1  # ~11km del centro
        for _ in range(4):
            lon = lon_centro + random.uniform(-radio, radio)
            lat = lat_centro + random.uniform(-radio, radio)
            puntos_asentamiento_funai.append([lon, lat])
    except:
        pass

print(f"Puntos generados: {len(puntos_asentamiento_funai)}")


