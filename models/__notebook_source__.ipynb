import torch
import numpy as np
from skimage.transform import resize
import requests
import io

# Cargar el mejor modelo
checkpoint = torch.load("/content/drive/MyDrive/SentinelWatch/gaia_ssl4eo_v4.pth")
clasificador.load_state_dict(checkpoint['clasificador'])
clasificador.eval()
backbone.eval()

def predecir_coord(coord, fecha_inicio="2023-06-01", fecha_fin="2023-10-31"):
    geom = ee.Geometry.Point(coord).buffer(1120)
    s2 = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
        .filterBounds(geom).filterDate(fecha_inicio, fecha_fin)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
        .median()
        .select(["B1","B2","B3","B4","B5","B6","B7","B8","B8A","B9","B11","B12"])
    )
    url = s2.getDownloadURL({"region": geom, "scale": 10, "format": "NPY"})
    response = requests.get(url)
    data = np.load(io.BytesIO(response.content))
    arr = np.stack([data[b] for b in ["B1","B2","B3","B4","B5","B6","B7","B8","B8A","B9","B11","B12"]], axis=-1)
    arr = resize(arr.astype(np.float32), (224, 224, 12), anti_aliasing=True)
    arr = arr / 10000.0
    arr = np.clip(arr, 0, 1)
    tensor = torch.tensor(arr.transpose(2,0,1), dtype=torch.float32).unsqueeze(0)
    b10 = torch.zeros(1, 1, 224, 224)
    tensor = torch.cat([tensor[:,:9], b10, tensor[:,9:]], dim=1).to(device)
    with torch.no_grad():
        features = backbone(tensor)
        salidas = clasificador(features)
        prob = torch.softmax(salidas, dim=1)
        pred = torch.argmax(salidas, dim=1).item()
    return pred, prob[0][1].item()

# Evaluar sobre coordenadas confirmadas
print("Evaluando sobre coordenadas verificadas manualmente:\n")

# Positivos confirmados
correctos_pos = 0
for coord in coords_confirmadas[:17]:  # 17 confirmadas como garimpo
