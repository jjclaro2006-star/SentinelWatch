import numpy as np
import rasterio

def calcular_ndwi(archivo):
    with rasterio.open(archivo) as src:
        img = src.read().astype(np.float32)
    b3 = img[1]
    b8 = img[3]
    ndwi = (b3 - b8) / (b3 + b8 + 1e-8)
    return ndwi.mean()

