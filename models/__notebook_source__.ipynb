# Zona Yanomami — garimpo confirmado por FUNAI e ISA
zona_yanomami = ee.Geometry.BBox(-64.5, -3.5, -62.0, -1.5)

# Sentinel-2 2023
s2 = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
    .filterBounds(zona_yanomami)
    .filterDate("2023-06-01", "2023-10-31")
    .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
    .median()
)

# MNDWI = (Verde - SWIR) / (Verde + SWIR)
# Alta turbidez = agua con sedimento = garimpo
mndwi = s2.normalizedDifference(["B3", "B11"])

# NDVI para separar vegetación
ndvi = s2.normalizedDifference(["B8", "B4"])

# Índice de suelo desnudo
bsi = s2.expression(
    "((SWIR + RED) - (NIR + BLUE)) / ((SWIR + RED) + (NIR + BLUE))",
    {
        "SWIR": s2.select("B11"),
        "RED": s2.select("B4"),
        "NIR": s2.select("B8"),
        "BLUE": s2.select("B2")
    }
)

# Detectar garimpo:
# 1. Suelo desnudo alto (BSI > 0.1)
# 2. Sin vegetación (NDVI < 0.2)
# 3. Cerca de agua (MNDWI variable)
garimpo_mask = bsi.gt(0.1).And(ndvi.lt(0.2))

# Contar píxeles
conteo = garimpo_mask.reduceRegion(
    reducer=ee.Reducer.sum(),
    geometry=zona_yanomami,
    scale=100,
    maxPixels=1e9
).getInfo()

print(f"Píxeles de posible garimpo en zona Yanomami: {int(list(conteo.values())[0]):,}")

# Samplear puntos
puntos = garimpo_mask.selfMask().sample(
    region=zona_yanomami,
    scale=100,
    numPixels=200,
    seed=42,
    geometries=True,
    tileScale=8
)

print(f"Puntos muestreados: {puntos.size().getInfo()}")


# Umbrales más permisivos
garimpo_mask = bsi.gt(0.0).And(ndvi.lt(0.3))

conteo = garimpo_mask.reduceRegion(
    reducer=ee.Reducer.sum(),
    geometry=zona_yanomami,
    scale=100,
    maxPixels=1e9
).getInfo()

