import os, io, time, requests
import numpy as np
import rasterio
from skimage.transform import resize

base_temporal = "/content/drive/MyDrive/SentinelWatch/data_v05_temporal"

def descargar_par_temporal(coord, config, archivo_dest):
    geom = ee.Geometry.Point(coord).buffer(320)

    def get_imagen_6b(fecha_inicio, fecha_fin):
        s2 = (ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED")
            .filterBounds(geom).filterDate(fecha_inicio, fecha_fin)
            .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", 20))
            .median().select(["B4","B3","B2","B8"]))
        s1 = (ee.ImageCollection("COPERNICUS/S1_GRD")
            .filterBounds(geom).filterDate(fecha_inicio, fecha_fin)
            .filter(ee.Filter.eq("instrumentMode","IW"))
            .filter(ee.Filter.listContains("transmitterReceiverPolarisation","VV"))
            .filter(ee.Filter.listContains("transmitterReceiverPolarisation","VH"))
            .select(["VV","VH"]).median())
        imagen = s2.addBands(s1)
        url = imagen.getDownloadURL({"region":geom,"scale":10,"format":"NPY"})
        response = requests.get(url)
        data = np.load(io.BytesIO(response.content))
        arr = np.stack([data["B4"],data["B3"],data["B2"],data["B8"],data["VV"],data["VH"]], axis=-1)
        return resize(arr.astype(np.float32), (64,64,6), anti_aliasing=True).astype(np.float32)

    img_t30 = get_imagen_6b(config["t30"][0], config["t30"][1])
    img_t0  = get_imagen_6b(config["t0"][0],  config["t0"][1])

    # Combinar en 12 bandas: (64, 64, 12)
    img_par = np.concatenate([img_t30, img_t0], axis=-1)

    # Guardar como (12, 64, 64)
    img_par = img_par.transpose(2, 0, 1)

    with rasterio.open(archivo_dest, "w", driver="GTiff",
                       height=64, width=64, count=12, dtype=np.float32) as dst:
        for b in range(12):
            dst.write(img_par[b], b+1)

# Fuentes de coordenadas por clase — reutilizamos las del v0.4_s1s2
print("Iniciando descarga de pares temporales...\n")
print("Esto va a tardar varias horas — ideal dejarlo esta noche\n")

for clase, config in config_temporal.items():
    carpeta_origen = f"/content/drive/MyDrive/SentinelWatch/data_v04_s1s2/{clase}"
    carpeta_dest   = f"{base_temporal}/{clase}"
    os.makedirs(carpeta_dest, exist_ok=True)

    # Leer coordenadas del centro de cada imagen existente
    archivos_origen = sorted([f for f in os.listdir(carpeta_origen) if f.endswith(".tif")])[:800]

    print(f"Descargando {clase} ({len(archivos_origen)} pares)...")
    errores = 0
    descargadas = 0

    for i, archivo in enumerate(archivos_origen):
        dest = os.path.join(carpeta_dest, f"par_{i:04d}.tif")
        if os.path.exists(dest):
            descargadas += 1
            continue

        try:
            # Leer coordenadas del archivo original
            with rasterio.open(os.path.join(carpeta_origen, archivo)) as src:
                bounds = src.bounds
                lon = (bounds.left + bounds.right) / 2
                lat = (bounds.top + bounds.bottom) / 2

            # Si no tiene georeferencia, usar coordenada por defecto de la clase
            if abs(lon) < 0.001 and abs(lat) < 0.001:
                raise ValueError("Sin georeferencia")

            descargar_par_temporal([lon, lat], config, dest)
            descargadas += 1
            if descargadas % 100 == 0:
                print(f"  {descargadas}/{len(archivos_origen)}")
        except:
            errores += 1

        time.sleep(0.4)

    print(f"  ✓ {clase}: {descargadas} pares, {errores} errores\n")

print("✓ Dataset temporal completo")


