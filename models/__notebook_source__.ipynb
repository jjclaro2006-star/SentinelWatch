        x, y = x.to(DEVICE), y.to(DEVICE)
        optimizer.zero_grad()
        loss = criterion(model(x).squeeze(1), y)
        loss.backward()
        optimizer.step()
        train_loss += loss.item()
    scheduler.step()

    model.eval()
    all_preds, all_labels = [], []
    with torch.no_grad():
        for x, y in val_loader:
            x, y = x.to(DEVICE), y.to(DEVICE)
            probs = torch.sigmoid(model(x).squeeze(1)).cpu().numpy()
            all_preds.extend(probs)
            all_labels.extend(y.cpu().numpy())

    auc          = roc_auc_score(all_labels, all_preds)
    preds_binary = [1 if p > 0.35 else 0 for p in all_preds]
    report       = classification_report(all_labels, preds_binary,
                       target_names=['no_intencional','intencional'],
                       output_dict=True, zero_division=0)

    recall    = report['intencional']['recall']
    precision = report['intencional']['precision']
    f1        = report['intencional']['f1-score']

    print(f"Epoch {epoch:02d} | Loss {train_loss/len(train_loader):.3f} | "
          f"AUC {auc:.3f} | Recall {recall:.3f} | "
          f"Precision {precision:.3f} | F1 {f1:.3f}")

    history.append({'epoch': epoch, 'auc': auc,
                    'recall': recall, 'precision': precision})

    if auc > best_auc and auc > 0.65:
        best_auc = auc
        torch.save({
            'epoch': epoch,
            'model_state_dict': model.state_dict(),
            'auc': auc, 'recall': recall, 'threshold': 0.35,
            'version': 'v0.2'
        }, os.path.join(WORK_DIR, "gaia_incendios_v02_best.pth"))
        print(f"  💾 Modelo guardado — AUC {auc:.3f}")

pd.DataFrame(history).to_csv(
    os.path.join(WORK_DIR, "training_history_v2.csv"), index=False)
print(f"\n✅ Entrenamiento completo — mejor AUC: {best_auc:.3f}")

