import time, ee
import numpy as np

WORK_DIR    = "/kaggle/working/"
NEW_PATCHES = os.path.join(WORK_DIR, "patches_v2/")
os.makedirs(NEW_PATCHES, exist_ok=True)

# Dataset limpio
df_clean = df_valid.reset_index(drop=True)
print(f"Descargando {len(df_clean)} parches...")

BANDS = ['B1','B2','B3','B4','B5','B6','B7','B8','B8A','B9','B11','B12']

def get_sentinel2_patch(lat, lon, date_str, patch_size=224, cloud_pct=20):
    point  = ee.Geometry.Point([lon, lat])
    region = point.buffer(1500).bounds()
    date   = pd.to_datetime(date_str)
    pre_start  = (date - pd.Timedelta(days=60)).strftime('%Y-%m-%d')
    pre_end    = (date - pd.Timedelta(days=5)).strftime('%Y-%m-%d')
    post_start = (date + pd.Timedelta(days=5)).strftime('%Y-%m-%d')
    post_end   = (date + pd.Timedelta(days=60)).strftime('%Y-%m-%d')

    def get_composite(start, end):
        return (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
                .filterBounds(point)
                .filterDate(start, end)
                .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', cloud_pct))
                .select(BANDS)
                .median())
    try:
        pre_img  = get_composite(pre_start, pre_end)
        post_img = get_composite(post_start, post_end)
        nbr_pre  = pre_img.normalizedDifference(['B8','B12'])
        nbr_post = post_img.normalizedDifference(['B8','B12'])
        dnbr     = nbr_pre.subtract(nbr_post).rename('dNBR')
        final    = (post_img.addBands(dnbr)
                   .reproject(crs='EPSG:32719', scale=10))
        data      = final.sampleRectangle(region=region, defaultValue=0)
        data_dict = data.getInfo()
        arrays = []
        for band in BANDS:
            arr = np.array(data_dict['properties'][band], dtype=np.float32)
            arr = arr[:patch_size, :patch_size]
            if arr.shape[0] < patch_size or arr.shape[1] < patch_size:
                arr = np.pad(arr, ((0, patch_size-arr.shape[0]),
                                   (0, patch_size-arr.shape[1])), mode='reflect')
            arrays.append(arr / 10000.0)
        dnbr_arr = np.array(data_dict['properties']['dNBR'], dtype=np.float32)
        dnbr_arr = dnbr_arr[:patch_size, :patch_size]
        if dnbr_arr.shape[0] < patch_size or dnbr_arr.shape[1] < patch_size:
            dnbr_arr = np.pad(dnbr_arr, ((0, patch_size-dnbr_arr.shape[0]),
                                          (0, patch_size-dnbr_arr.shape[1])), mode='reflect')
        arrays.append(np.clip(dnbr_arr, -2, 2))
        patch = np.stack(arrays, axis=-1)
        return patch if patch.shape == (patch_size, patch_size, 13) else None
    except Exception:
        return None

# Verificar cuáles ya están descargados
existing_idx = {int(f.replace('v2_','').replace('.npy',''))
                for f in os.listdir(NEW_PATCHES)
                if f.endswith('.npy') and f.startswith('v2_')}
missing_idx  = set(df_clean.index.tolist()) - existing_idx
print(f"Ya descargados: {len(existing_idx)}")
print(f"A descargar:    {len(missing_idx)}")

results = []
failed  = 0

for idx in tqdm(sorted(missing_idx), desc="Descargando v2"):
    row        = df_clean.loc[idx]
    patch_path = os.path.join(NEW_PATCHES, f"v2_{idx}.npy")
    patch      = get_sentinel2_patch(row['lat'], row['lon'], row['fecha_iso'])

    if patch is not None:
        np.save(patch_path, patch)
        results.append({'idx': idx, 'label': row['label'],
                        'path': patch_path, 'ok': True})
    else:
        failed += 1
        results.append({'idx': idx, 'label': row['label'],
                        'path': None, 'ok': False})

    if len(results) % 50 == 0:
        pd.DataFrame(results).to_csv(
            os.path.join(WORK_DIR, "manifest_v2.csv"), index=False)

    time.sleep(0.5)

pd.DataFrame(results).to_csv(
    os.path.join(WORK_DIR, "manifest_v2.csv"), index=False)
print(f"\n✅ OK: {len(results)-failed} | Fallidos: {failed}")
print(f"\n⚠️  IMPORTANTE: Save Version antes de cerrar")


import os, random
import numpy as np, pandas as pd
import torch, torch.nn as nn
import matplotlib.pyplot as plt
from torch.utils.data import Dataset, DataLoader
from sklearn.model_selection import train_test_split
from sklearn.metrics import (classification_report, roc_auc_score,
                             confusion_matrix, roc_curve)
import timm

SEED          = 42
WORK_DIR      = "/kaggle/working/"
NEW_PATCHES   = os.path.join(WORK_DIR, "patches_v2/")
BACKBONE_PATH = "/kaggle/input/datasets/juanclaro/ssl4eo/B13_vits16_moco_0099.pth"

random.seed(SEED); np.random.seed(SEED); torch.manual_seed(SEED)
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"✅ Device: {DEVICE}")

# ─────────────────────────────────────────────────────────────
# MANIFEST
# ─────────────────────────────────────────────────────────────
manifest = pd.read_csv(os.path.join(WORK_DIR, "manifest_v2.csv"))
manifest_ok = manifest[manifest['ok'] == True].reset_index(drop=True)
print(f"✅ Parches válidos: {len(manifest_ok)}")
print(f"   Positivos: {manifest_ok['label'].sum()}")
print(f"   Negativos: {(manifest_ok['label']==0).sum()}")

train_manifest, val_manifest = train_test_split(
    manifest_ok, test_size=0.2,
    stratify=manifest_ok['label'],
    random_state=SEED)
print(f"Train: {len(train_manifest)} | Val: {len(val_manifest)}")

# ─────────────────────────────────────────────────────────────
# DATASET
# ─────────────────────────────────────────────────────────────
class IncendiosDataset(Dataset):
    def __init__(self, df, augment=False):
        self.data    = df.reset_index(drop=True)
        self.augment = augment

    def __len__(self): return len(self.data)

    def __getitem__(self, idx):
        row   = self.data.iloc[idx]
        patch = np.load(row['path'])
        if self.augment:
            if random.random() > 0.5: patch = np.fliplr(patch)
            if random.random() > 0.5: patch = np.flipud(patch)
            patch = np.rot90(patch, random.randint(0, 3))
        patch = np.ascontiguousarray(patch).transpose(2, 0, 1)
        return (torch.tensor(patch, dtype=torch.float32),
                torch.tensor(row['label'], dtype=torch.float32))

train_dataset = IncendiosDataset(train_manifest, augment=True)
val_dataset   = IncendiosDataset(val_manifest,   augment=False)
train_loader  = DataLoader(train_dataset, batch_size=16, shuffle=True,
                           num_workers=2, pin_memory=True)
val_loader    = DataLoader(val_dataset,   batch_size=16, shuffle=False,
                           num_workers=2, pin_memory=True)

# ─────────────────────────────────────────────────────────────
# MODELO
# ─────────────────────────────────────────────────────────────
class GaiaIncendios(nn.Module):
    def __init__(self, backbone_path):
        super().__init__()
        self.backbone = timm.create_model(
            'vit_small_patch16_224', pretrained=False, in_chans=13)

        state      = torch.load(backbone_path, map_location='cpu')
        state_dict = state.get('state_dict', state)
        remapped   = {k[len('module.base_encoder.'):]: v
                      for k, v in state_dict.items()
                      if k.startswith('module.base_encoder.')}

        missing, unexpected = self.backbone.load_state_dict(remapped, strict=False)
        print(f"Backbone — missing: {len(missing)} | unexpected: {len(unexpected)}")

        for param in self.backbone.parameters():
            param.requires_grad = False

        self.classifier = nn.Sequential(
            nn.Linear(self.backbone.embed_dim, 256),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(256, 1)
        )

    def forward(self, x):
        with torch.no_grad():
            features = self.backbone.forward_features(x)
            if features.ndim == 3:
                features = features[:, 0, :]
        return self.classifier(features)

model = GaiaIncendios(BACKBONE_PATH).to(DEVICE)

# ─────────────────────────────────────────────────────────────
# ENTRENAMIENTO — 20 épocas rápidas
# ─────────────────────────────────────────────────────────────
pos_weight = torch.tensor([1.5]).to(DEVICE)
criterion  = nn.BCEWithLogitsLoss(pos_weight=pos_weight)
optimizer  = torch.optim.AdamW(model.classifier.parameters(),
                               lr=1e-3, weight_decay=1e-4)
scheduler  = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=20)

best_auc = 0.0
history  = []

print("\n🚀 Entrenando 20 épocas...")
for epoch in range(1, 21):
    model.train()
    train_loss = 0.0
    for x, y in train_loader:
        x, y = x.to(DEVICE), y.to(DEVICE)
        optimizer.zero_grad()
        loss = criterion(model(x).squeeze(1), y)
        loss.backward()
        optimizer.step()
        train_loss += loss.item()
    scheduler.step()

    model.eval()
    all_preds, all_labels = [], []
    with torch.no_grad():
        for x, y in val_loader:
            x, y = x.to(DEVICE), y.to(DEVICE)
            probs = torch.sigmoid(model(x).squeeze(1)).cpu().numpy()
            all_preds.extend(probs)
            all_labels.extend(y.cpu().numpy())

    auc          = roc_auc_score(all_labels, all_preds)
    preds_binary = [1 if p > 0.35 else 0 for p in all_preds]
    report       = classification_report(all_labels, preds_binary,
                       target_names=['no_intencional','intencional'],
                       output_dict=True, zero_division=0)

    recall    = report['intencional']['recall']
    precision = report['intencional']['precision']
    f1        = report['intencional']['f1-score']

    print(f"Epoch {epoch:02d} | Loss {train_loss/len(train_loader):.3f} | "
          f"AUC {auc:.3f} | Recall {recall:.3f} | "
          f"Precision {precision:.3f} | F1 {f1:.3f}")

    history.append({'epoch': epoch, 'auc': auc,
                    'recall': recall, 'precision': precision})

    if auc > best_auc and auc > 0.65:
        best_auc = auc
        torch.save({
            'epoch': epoch,
            'model_state_dict': model.state_dict(),
            'auc': auc, 'recall': recall, 'threshold': 0.35,
            'version': 'v0.2'
        }, os.path.join(WORK_DIR, "gaia_incendios_v02_best.pth"))
        print(f"  💾 Modelo guardado — AUC {auc:.3f}")

pd.DataFrame(history).to_csv(
    os.path.join(WORK_DIR, "training_history_v2.csv"), index=False)
print(f"\n✅ Mejor AUC: {best_auc:.3f}")


