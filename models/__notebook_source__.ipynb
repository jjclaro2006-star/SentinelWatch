# GHSL detecta edificios a 10m
# Cruzado con WDPA = edificios ilegales en zonas protegidas

ghsl = ee.Image("JRC/GHSL/P2023A/GHS_BUILT_S/2020")
latam = ee.Geometry.BBox(-82, -56, -34, 13)

# Buscar en subregiones pequeñas donde hay más actividad ilegal
subregiones_asentamiento = [
    ee.Geometry.BBox(-63, -13, -58, -8),   # Rondônia
    ee.Geometry.BBox(-52, -8,  -47, -3),   # Pará
    ee.Geometry.BBox(-70, -13, -65, -8),   # Madre de Dios Perú
    ee.Geometry.BBox(-77, -2,  -72,  3),   # Colombia Putumayo
    ee.Geometry.BBox(-64, -4,  -58,  2),   # Amazonas Brasil
    ee.Geometry.BBox(-62, -16, -56, -10),  # Bolivia norte
]

wdpa = ee.FeatureCollection("WCMC/WDPA/current/polygons").filterBounds(latam)

todos_puntos = []

for i, region in enumerate(subregiones_asentamiento):
    try:
        # Edificios dentro de áreas protegidas
        edificios_ilegales = ghsl.gt(0).clip(wdpa.filterBounds(region))

        # Contar píxeles disponibles
        conteo = edificios_ilegales.reduceRegion(
            reducer=ee.Reducer.sum(),
            geometry=region,
            scale=100,
            maxPixels=1e8
        ).getInfo()

        pixeles = int(list(conteo.values())[0]) if conteo else 0
        print(f"Subregión {i+1}: {pixeles:,} píxeles de edificios ilegales")

        if pixeles > 0:
            puntos = edificios_ilegales.selfMask().sample(
                region=region,
                scale=50,
                numPixels=200,
                seed=42,
                geometries=True,
                tileScale=8
            )
            cantidad = puntos.size().getInfo()
            if cantidad > 0:
                todos_puntos.append(puntos)
                print(f"  → {cantidad} puntos muestreados")
    except Exception as e:
        print(f"Subregión {i+1}: error")

total = sum(p.size().getInfo() for p in todos_puntos) if todos_puntos else 0
print(f"\nTotal puntos asentamiento ilegal: {total}")


