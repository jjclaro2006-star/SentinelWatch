        ee.Geometry.BBox(-44, -10, -40, -5),  ee.Geometry.BBox(-48, -10, -44, -5),
    ]
    col_pre  = None
    col_post = None
    todos = []
    for r in subregiones:
        try:
            pre  = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED").filterBounds(r).filterDate("2023-04-01","2023-06-30").filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE",20)).median()
            post = ee.ImageCollection("COPERNICUS/S2_SR_HARMONIZED").filterBounds(r).filterDate("2023-08-01","2023-10-31").filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE",20)).median()
            dnbr = pre.normalizedDifference(["B8","B12"]).subtract(post.normalizedDifference(["B8","B12"]))
            p = dnbr.gt(0.27).selfMask().sample(region=r, scale=200, numPixels=300, seed=42, geometries=True, tileScale=4)
