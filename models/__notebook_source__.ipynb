# Negativos confirmados
correctos_neg = 0
coords_neg_test = [[-55.4291, 4.9224],[-59.8835, 7.0042],[-54.3391, -7.4226],
                   [-54.2926, 5.2721],[-49.7347, -6.0666],[-51.2143, -5.8977],
                   [-57.6597, -6.7361],[-55.4833, 4.9965],[-55.6625, -9.8238],
                   [-57.5223, -6.9036]]

for coord in coords_neg_test:
    try:
        pred, prob = predecir_coord(coord, "2023-01-01", "2024-01-01")
        correctos_neg += (pred == 0)
    except:
        pass

print(f"Positivos (garimpo): {correctos_pos}/17 correctos")
print(f"Negativos (no garimpo): {correctos_neg}/10 correctos")
print(f"\nPrecisión en datos verificados: {(correctos_pos+correctos_neg)/27*100:.1f}%")


print("Evaluando con diferentes umbrales:\n")

resultados = []

for coord in coords_confirmadas[:17]:
    try:
        pred, prob = predecir_coord(coord)
        resultados.append((1, prob))  # real=mineria, prob=mineria
    except:
        pass

for coord in coords_neg_test:
    try:
        pred, prob = predecir_coord(coord, "2023-01-01", "2024-01-01")
        resultados.append((0, prob))  # real=normal
    except:
        pass

print(f"{'Umbral':>8} | {'Precisión':>10} | {'Recall minería':>15} | {'Falsos positivos':>17}")
print("-" * 60)

for umbral in [0.5, 0.6, 0.7, 0.75, 0.8, 0.85, 0.9]:
    correctos = 0
    tp = fp = tn = fn = 0
    for real, prob in resultados:
        pred = 1 if prob >= umbral else 0
        if real == 1 and pred == 1: tp += 1
        elif real == 0 and pred == 0: tn += 1
        elif real == 0 and pred == 1: fp += 1
        elif real == 1 and pred == 0: fn += 1

    total = tp + fp + tn + fn
    precision = (tp + tn) / total if total > 0 else 0
    recall = tp / (tp + fn) if (tp + fn) > 0 else 0

    print(f"{umbral:>8.2f} | {precision*100:>9.1f}% | {recall*100:>14.1f}% | {fp:>17}")

print()


