def get_puntos_incendio():
    subregiones = [
        ee.Geometry.BBox(-52, -15, -48, -10), ee.Geometry.BBox(-48, -15, -44, -10),
        ee.Geometry.BBox(-52, -18, -48, -15), ee.Geometry.BBox(-56, -15, -52, -10),
